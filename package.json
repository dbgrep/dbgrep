{
  "name": "dbgrep",
  "version": "1.0.0",
  "description": "Desktop database browser with SQL query support",
  "license": "Apache-2.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "start": "env -u ELECTRON_RUN_AS_NODE vite"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "better-sqlite3": "^11.10.0",
    "knex": "^3.1.0",
    "monaco-editor": "^0.55.1",
    "mysql2": "^3.14.1",
    "pg": "^8.16.0",
    "sql-formatter": "^15.8.1",
    "tedious": "^18.6.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.dbgrep.app",
    "productName": "DBGrep",
    "icon": "src/assets/dbgrep-icon-1024.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "src/assets/dbgrep-icon-512.png",
        "to": "icon.png"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools"
    }
  }
}
