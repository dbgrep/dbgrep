# Copy to .env.signing and fill in your values. Never commit .env.signing.

# --- macOS (cert already in Keychain) ---
# List identities: security find-identity -v -p codesigning
# Use "Name (TEAMID)" only — omit the "Developer ID Application:" prefix from Keychain.
CSC_NAME="Your Name (TEAMID)"
APPLE_ID=you@example.com
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
APPLE_TEAM_ID=XXXXXXXXXX

# --- macOS (cert as .p12 file instead of Keychain) ---
# Uncomment these and comment out CSC_NAME above.
# CSC_LINK=/absolute/path/to/DeveloperIDApplication.p12
# CSC_KEY_PASSWORD=your-p12-password

# --- Windows (.pfx certificate) ---
# CSC_LINK=/absolute/path/to/codesign.pfx
# CSC_KEY_PASSWORD=your-pfx-password
